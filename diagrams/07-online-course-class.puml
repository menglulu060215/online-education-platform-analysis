@startuml
class 用户 {
  +用户ID
  +姓名
}
class 学生 {
  +学号
  +邮箱
}
class 教师 {
  +工号
  +邮箱
}
class 课程目录
class 课程 {
  +课程ID
  +课程名
  +讲师
}
class 选课记录 {
  +记录ID
  +选课时间
}
class 支付记录 {
  +支付ID
  +金额
}

用户 <|-- 学生
用户 <|-- 教师

课程目录 o-- "0..*" 课程 : 聚合
学生 "1" -- "0..*" 选课记录 : 关联
课程 "1" -- "0..*" 选课记录 : 关联
选课记录 "0..1" *-- "1" 支付记录 : 组合（如选课需支付）

@enduml
